# Nginx configuration for Nomadic Townies API
# Place this file at: /etc/nginx/sites-available/nomadic-api
# Or modify your existing nginx configuration

server {
    listen 80;
    server_name api.nomadictownies.com;

    # Increase client body size limit to support large file uploads (500MB)
    client_max_body_size 500M;
    
    # Increase buffer sizes for large requests
    client_body_buffer_size 500M;
    
    # Increase timeouts for large file uploads
    client_body_timeout 300s;
    send_timeout 300s;
    
    # Proxy settings
    proxy_connect_timeout 300s;
    proxy_send_timeout 300s;
    proxy_read_timeout 300s;
    proxy_buffering off;
    proxy_request_buffering off;

    location / {
        proxy_pass http://127.0.0.1:5000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}

# If you're using HTTPS (recommended), add this server block too:
server {
    listen 443 ssl http2;
    server_name api.nomadictownies.com;

    # SSL certificate paths (update these with your actual certificate paths)
    # ssl_certificate /etc/letsencrypt/live/api.nomadictownies.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/api.nomadictownies.com/privkey.pem;

    # Increase client body size limit to support large file uploads (500MB)
    client_max_body_size 500M;
    
    # Increase buffer sizes for large requests
    client_body_buffer_size 500M;
    
    # Increase timeouts for large file uploads
    client_body_timeout 300s;
    send_timeout 300s;
    
    # Proxy settings
    proxy_connect_timeout 300s;
    proxy_send_timeout 300s;
    proxy_read_timeout 300s;
    proxy_buffering off;
    proxy_request_buffering off;

    location / {
        proxy_pass http://127.0.0.1:5000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}

